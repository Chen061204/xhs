# Optional server fallback. A request Bearer key always takes precedence.
TOKENHUB_API_KEY=replace-with-tencent-tokenhub-key

# Tencent TokenHub OpenAI-compatible endpoint and DeepSeek model.
TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TOKENHUB_MODEL=deepseek-v4-pro-202606
TOKENHUB_SEARCH_MODEL=deepseek-v4-pro

# Comma-separated allowlist for the optional X-TokenHub-Model request header.
TOKENHUB_ALLOWED_MODELS=deepseek-v4-pro-202606,deepseek-v4-pro
TOKENHUB_TIMEOUT_SECONDS=90
TOKENHUB_SEARCH_SOURCE=lite

# Use exact frontend origins in production. Do not add a trailing slash.
CORS_ORIGINS=https://your-frontend.example.com
